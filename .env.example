# Groq API Configuration
GROQ_API_KEY=your_groq_free_tier_key_here

# IBM Watson AI Services (Optional - for advanced features)
WATSON_API_KEY=your_watson_api_key_here
WATSON_URL=your_watson_url_here

# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=owner/repo-name

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./data/chroma

# Demo Mode (set to true to use mock data)
DEMO_MODE=true

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend Configuration
FRONTEND_PORT=5173